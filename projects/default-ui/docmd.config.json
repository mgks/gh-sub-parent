{
  "title": "Default UI + Showcase",
  "engine": "js",
  "layout": {
    "spa": true,
    "breadcrumbs": true,
    "header": { "enabled": true },
    "sidebar": { "collapsible": true, "defaultCollapsed": false },
    "menubar": {
      "enabled": true,
      "position": "top",
      "left": [
        { "text": "Home", "url": "/" },
        { "text": "Mermaid", "url": "/mermaid/" },
        { "text": "Math", "url": "/math/" },
        { "text": "Containers", "url": "/containers/" }
      ]
    },
    "optionsMenu": {
      "position": "header",
      "components": { "search": true, "themeSwitch": true }
    },
    "footer": { "style": "complete", "content": "docmd beta-test · Default UI + Showcase", "branding": true }
  },
  "theme": { "name": "default", "appearance": "auto", "codeHighlight": true },
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Home", "path": "/" },
    { "title": "Containers", "path": "/containers/" },
    {
      "title": "Nested Category",
      "children": [
        { "title": "Math Rendering", "path": "/math/" },
        { "title": "Mermaid Diagrams", "path": "/mermaid/" },
        {
          "title": "Subnested Category",
          "children": [
            { "title": "Nested Page A", "path": "/nested/page-a/" },
            { "title": "Nested Page B", "path": "/nested/subnested/page-b/" }
          ]
        }
      ]
    }
  ],
  "plugins": {
    "math": true,
    "mermaid": true,
    "seo": { "defaultDescription": "Default UI + Showcase — testing every UI component, callout block, and plugin rendering." }
  }
}
