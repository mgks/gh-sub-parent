{
  "name": "embed-lite",
  "version": "0.1.4",
  "description": "Zero-dependency, static URL-to-HTML embed parser for markdown and browser.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prep": "rm -rf dist node_modules package-lock.json && npm install && npm run build",
    "build": "tsc && npm run build:cdn && npm run build:cdn:min && cp -r public/* dist/",
    "build:cdn": "esbuild src/index.ts --bundle --global-name=embedLite --outfile=dist/embed-lite.global.js",
    "build:cdn:min": "esbuild src/index.ts --bundle --global-name=embedLite --outfile=dist/embed-lite.global.min.js --minify"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "embed",
    "url",
    "iframe",
    "static",
    "oembed",
    "parser",
    "docmd",
    "youtube",
    "twitter",
    "vimeo",
    "facebook",
    "instagram",
    "tiktok",
    "spotify",
    "soundcloud",
    "maps",
    "reddit",
    "github",
    "linkedin",
    "x"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgks/embed-lite.git"
  },
  "bugs": {
    "url": "https://github.com/mgks/embed-lite/issues"
  },
  "homepage": "https://embed.mgks.dev",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}