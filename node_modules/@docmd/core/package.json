{
  "name": "@docmd/core",
  "version": "0.8.16",
  "description": "Build production-ready documentation from Markdown in seconds. No React, no bloat, just content.",
  "type": "module",
  "browser": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docmd": "dist/bin/docmd.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/docmd.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@docmd/api": "^0.8.16",
    "@docmd/deployer": "^0.8.16",
    "@docmd/live": "^0.8.16",
    "@docmd/parser": "^0.8.16",
    "@docmd/plugin-analytics": "^0.8.16",
    "@docmd/plugin-git": "^0.8.16",
    "@docmd/plugin-installer": "^0.8.16",
    "@docmd/plugin-llms": "^0.8.16",
    "@docmd/plugin-mermaid": "^0.8.16",
    "@docmd/plugin-okf": "^0.8.16",
    "@docmd/plugin-openapi": "^0.8.16",
    "@docmd/plugin-search": "^0.8.16",
    "@docmd/plugin-seo": "^0.8.16",
    "@docmd/plugin-sitemap": "^0.8.16",
    "@docmd/themes": "^0.8.16",
    "@docmd/tui": "^0.8.16",
    "@docmd/ui": "^0.8.16",
    "@docmd/utils": "^0.8.16",
    "esbuild": "^0.28.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3"
  },
  "allowScripts": {
    "esbuild": true,
    "@docmd/engine-rust": true,
    "onnxruntime-node": true,
    "protobufjs": true,
    "sharp": true
  },
  "keywords": [
    "docmd",
    "markdown",
    "minimalist",
    "zero-config",
    "site-generator",
    "static-site-generator",
    "documentation",
    "typescript",
    "javascript",
    "nodejs",
    "browser",
    "website",
    "generator",
    "hosted",
    "cli",
    "ssg",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}